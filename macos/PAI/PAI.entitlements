<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  The embedded Python runtime (Contents/Resources/runtime/python) loads
	  many .dylib/.so at import time. Under the hardened runtime, library
	  validation requires every loaded Mach-O to share the app's Team ID.
	  While we sign ad-hoc ("-") there is no Team ID to match, so we must
	  disable library validation. When we migrate to a Developer ID identity
	  this can stay (simplest) or be dropped once every embedded lib is
	  co-signed with the same Team ID. See [[pai-app-consolidation]].
	-->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	<!-- CPython's interpreter loop / some C extensions need writable+exec and JIT-ish pages. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	<!-- Allow DYLD_* and PYTHON* environment overrides we pass to the kernel child. -->
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
</dict>
</plist>
