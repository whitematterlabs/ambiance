<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  PAI kernel LaunchAgent.

  Install (replace YOUR_HOME with `echo $HOME` if the literal doesn't expand):
    cp macos/launchd/com.pai.kernel.plist ~/Library/LaunchAgents/
    /usr/bin/sed -i '' "s|YOUR_HOME|$HOME|g" ~/Library/LaunchAgents/com.pai.kernel.plist
    launchctl bootstrap gui/$UID ~/Library/LaunchAgents/com.pai.kernel.plist
    launchctl enable gui/$UID/com.pai.kernel
    launchctl kickstart -k gui/$UID/com.pai.kernel

  Uninstall:
    launchctl bootout gui/$UID ~/Library/LaunchAgents/com.pai.kernel.plist
    rm ~/Library/LaunchAgents/com.pai.kernel.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pai.kernel</string>

    <key>ProgramArguments</key>
    <array>
        <string>YOUR_HOME/.pai/usr/bin/python</string>
        <string>-m</string>
        <string>boot</string>
        <string>run</string>
    </array>

    <key>WorkingDirectory</key>
    <string>YOUR_HOME/.pai</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PAI_ROOT</key>
        <string>YOUR_HOME/.pai</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!--
      Throttle restart attempts. Without this, a kernel that crashes during
      bootstrap will be re-spawned in a tight loop.
    -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>YOUR_HOME/.pai/var/log/kernel.out.log</string>

    <key>StandardErrorPath</key>
    <string>YOUR_HOME/.pai/var/log/kernel.err.log</string>

    <!--
      ProcessType=Interactive: scheduled like a foreground app, not throttled
      as a background daemon. The kernel does interactive work on the owner's
      behalf and should not be aggressively suspended by macOS.
    -->
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
