# macOS Finder metadata
.DS_Store

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

.venv
.env
.env.local

# FHS slots — runtime state lives at $PAI_ROOT (default ~/.pai). These
# only appear at the repo root if someone runs paifs-init in-tree.
/boot/
/bin/
/home/
/mnt/
/opt/
/proc/
/root/
/run/
/sbin/
/sys/
/tmp/
/usr/
/var/

# Abandoned IMAP/maildir driver work — kept locally for reference, not shipped.
/deprecated/

# Per-owner / per-environment files — not shipped.
/src/etc/owner.md
/src/usr/share/doc/built/

# macOS app — Xcode user state and build artifacts (sources under macos/PAI/ stay tracked).
/macos/PAI.xcodeproj/xcuserdata/
/macos/PAI.xcodeproj/project.xcworkspace/xcuserdata/
/macos/build/
/macos/DerivedData/
.gstack/
