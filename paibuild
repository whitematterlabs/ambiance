#!/usr/bin/env python3
"""Build the production PAI.app from the repo.

Repo-only developer utility. This file is intentionally not a pyproject
console script: it must never be installed into ~/.pai or emitted as an FHS
runtime shim.
"""

from __future__ import annotations

import argparse
import ast
import base64
import csv
from dataclasses import dataclass
import hashlib
import io
import json
import os
from pathlib import Path
import shutil
import subprocess
import sys
import tempfile
import zipfile


PYVER = "3.14"
STATE_VERSION = 1
DEFAULT_SIGN_ID = "-"
DEFAULT_NOTARY_PROFILE = "PAI"

SKIP_DIRS = {
    ".git",
    ".mypy_cache",
    ".pytest_cache",
    "__pycache__",
    "DerivedData",
    "build",
    "dist",
    "node_modules",
    "xcuserdata",
}
SKIP_SUFFIXES = {".pyc", ".pyo", ".DS_Store"}


@dataclass(frozen=True)
class Options:
    config: str
    full: bool = False
    dmg: bool = False
    notarize: bool = False
    dry_run: bool = False
    skip_registry_check: bool = False


@dataclass(frozen=True)
class Paths:
    repo: Path

    @property
    def macos(self) -> Path:
        return self.repo / "macos"

    @property
    def build_dir(self) -> Path:
        return self.macos / "build"

    @property
    def state_file(self) -> Path:
        return self.build_dir / ".paibuild-state.json"

    @property
    def derived_data(self) -> Path:
        return self.build_dir / "DerivedData"

    @property
    def final_app(self) -> Path:
        return self.build_dir / "PAI.app"

    @property
    def dmg(self) -> Path:
        return self.build_dir / "PAI.dmg"

    @property
    def wheel_dir(self) -> Path:
        return self.build_dir / "wheels"

    def derived_app(self, config: str) -> Path:
        return self.derived_data / "Build" / "Products" / config / "PAI.app"

    @property
    def web_dir(self) -> Path:
        return self.repo / "src" / "usr" / "libexec" / "web"

    @property
    def web_dist(self) -> Path:
        return self.web_dir / "dist"

    @property
    def app_runtime(self) -> Path:
        return self.final_app / "Contents" / "Resources" / "runtime"

    @property
    def app_python(self) -> Path:
        return self.app_runtime / "python" / "bin" / "python3"

    @property
    def app_seed(self) -> Path:
        return self.final_app / "Contents" / "Resources" / "seed"

    @property
    def app_web_dist(self) -> Path:
        return (
            self.final_app
            / "Contents"
            / "Resources"
            / "usr"
            / "libexec"
            / "web"
            / "dist"
        )


@dataclass
class BuildPlan:
    registry_check: bool
    web_deps: bool
    web: bool
    swift: bool
    full_runtime: bool
    python_package: bool
    seed: bool
    web_assets: bool
    sign: bool
    dmg: bool
    reasons: dict[str, str]


class Runner:
    def run(
        self,
        cmd: list[str],
        *,
        cwd: Path | None = None,
        env: dict[str, str] | None = None,
    ) -> None:
        subprocess.run(cmd, cwd=cwd, env=env, check=True)


def _is_skipped(path: Path) -> bool:
    if path.name in SKIP_DIRS or path.name in SKIP_SUFFIXES:
        return True
    return path.suffix in SKIP_SUFFIXES


def iter_files(path: Path) -> list[Path]:
    if not path.exists():
        return []
    if path.is_file() or path.is_symlink():
        return [path]
    files: list[Path] = []
    for child in sorted(path.iterdir(), key=lambda p: p.name):
        if _is_skipped(child):
            continue
        if child.is_dir() and not child.is_symlink():
            files.extend(iter_files(child))
        elif child.is_file() or child.is_symlink():
            files.append(child)
    return files


def digest_paths(root: Path, paths: list[Path]) -> str:
    h = hashlib.sha256()
    for path in sorted(paths, key=lambda p: str(p.relative_to(root))):
        rel = path.relative_to(root).as_posix()
        h.update(rel.encode())
        h.update(b"\0")
        if path.is_symlink():
            h.update(b"symlink\0")
            h.update(os.readlink(path).encode())
            h.update(b"\0")
            continue
        if not path.exists():
            h.update(b"missing\0")
            continue
        h.update(b"file\0")
        h.update(path.read_bytes())
        h.update(b"\0")
    return h.hexdigest()


def digest_inputs(paths: Paths) -> dict[str, str]:
    repo = paths.repo
    web_inputs = [
        paths.web_dir / "package.json",
        paths.web_dir / "pnpm-lock.yaml",
        paths.web_dir / "tsconfig.json",
        paths.web_dir / "vite.config.ts",
        paths.web_dir / "index.html",
        *iter_files(paths.web_dir / "src"),
    ]
    web_deps = [
        paths.web_dir / "package.json",
        paths.web_dir / "pnpm-lock.yaml",
    ]
    swift_inputs = [
        paths.macos / "project.yml",
        *iter_files(paths.macos / "PAI"),
    ]
    runtime_inputs = [
        repo / "pyproject.toml",
        repo / "uv.lock",
        paths.macos / "bundle-runtime.sh",
    ]
    python_inputs = [
        repo / "paibuild",
        repo / "pyproject.toml",
        *iter_files(repo / "src" / "boot"),
        *iter_files(repo / "src" / "bin"),
        *iter_files(repo / "src" / "sbin"),
        *iter_files(repo / "src" / "usr" / "libexec" / "web" / "pai_web"),
        *iter_files(paths.web_dist),
    ]
    seed_inputs = [
        *iter_files(repo / "src" / "etc"),
        *iter_files(repo / "src" / "usr" / "share" / "doc"),
    ]
    web_dist_inputs = [*iter_files(paths.web_dist)]
    return {
        "web": digest_paths(repo, web_inputs),
        "web_deps": digest_paths(repo, web_deps),
        "swift": digest_paths(repo, swift_inputs),
        "runtime": digest_paths(repo, runtime_inputs),
        "python": digest_paths(repo, python_inputs),
        "seed": digest_paths(repo, seed_inputs),
        "web_dist": digest_paths(repo, web_dist_inputs),
    }


def load_state(path: Path) -> dict:
    try:
        with path.open() as f:
            data = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}
    if data.get("version") != STATE_VERSION:
        return {}
    return data


def save_state(paths: Paths, options: Options, fingerprints: dict[str, str]) -> None:
    paths.build_dir.mkdir(parents=True, exist_ok=True)
    data = {
        "version": STATE_VERSION,
        "config": options.config,
        "fingerprints": fingerprints,
    }
    paths.state_file.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")


def make_plan(paths: Paths, options: Options, state: dict, fp: dict[str, str]) -> BuildPlan:
    state_fp = state.get("fingerprints") or {}
    app_exists = paths.final_app.is_dir()
    runtime_exists = paths.app_python.is_file()
    dist_exists = (paths.web_dist / "index.html").is_file()
    node_modules = paths.web_dir / "node_modules" / ".modules.yaml"
    config_changed = state.get("config") != options.config

    reasons: dict[str, str] = {}

    def changed(key: str) -> bool:
        return state_fp.get(key) != fp.get(key)

    web = not dist_exists or changed("web")
    if web:
        reasons["web"] = "missing dist" if not dist_exists else "frontend inputs changed"

    web_deps = web and (not node_modules.exists() or changed("web_deps"))
    if web_deps:
        reasons["web_deps"] = "missing node_modules" if not node_modules.exists() else "frontend deps changed"

    swift = options.full or not app_exists or config_changed or changed("swift")
    if swift:
        if options.full:
            reasons["swift"] = "--full"
        elif not app_exists:
            reasons["swift"] = "missing final app"
        elif config_changed:
            reasons["swift"] = "configuration changed"
        else:
            reasons["swift"] = "Swift app inputs changed"

    full_runtime = (
        options.full
        or not app_exists
        or not runtime_exists
        or changed("runtime")
    )
    if full_runtime:
        if options.full:
            reasons["full_runtime"] = "--full"
        elif not app_exists:
            reasons["full_runtime"] = "missing final app"
        elif not runtime_exists:
            reasons["full_runtime"] = "missing embedded Python"
        else:
            reasons["full_runtime"] = "runtime/dependency inputs changed"

    python_package = full_runtime or web or changed("python")
    if python_package and not full_runtime:
        reasons["python_package"] = "web dist changed" if web else "Python package inputs changed"

    seed = full_runtime or changed("seed")
    if seed and not full_runtime:
        reasons["seed"] = "seed inputs changed"

    web_assets = full_runtime or web or changed("web_dist")
    if web_assets and not full_runtime:
        reasons["web_assets"] = "web dist changed"

    sign = swift or full_runtime or python_package or seed or web_assets
    if sign:
        reasons["sign"] = "app bundle contents changed"

    registry_check = not options.skip_registry_check
    if registry_check:
        reasons["registry_check"] = "validate first-run seed packages"

    return BuildPlan(
        registry_check=registry_check,
        web_deps=web_deps,
        web=web,
        swift=swift,
        full_runtime=full_runtime,
        python_package=python_package,
        seed=seed,
        web_assets=web_assets,
        sign=sign,
        dmg=options.dmg,
        reasons=reasons,
    )


def print_plan(plan: BuildPlan) -> None:
    steps = [
        ("registry-check", plan.registry_check),
        ("web-deps", plan.web_deps),
        ("web", plan.web),
        ("swift", plan.swift),
        ("full-runtime", plan.full_runtime),
        ("python-package", plan.python_package),
        ("seed", plan.seed),
        ("web-assets", plan.web_assets),
        ("sign", plan.sign),
        ("dmg", plan.dmg),
    ]
    print("paibuild plan:", flush=True)
    for key, enabled in steps:
        if enabled:
            reason = plan.reasons.get(key.replace("-", "_"), plan.reasons.get(key, "requested"))
            print(f"  rebuild {key}: {reason}", flush=True)
        else:
            print(f"  skip    {key}: up to date", flush=True)


def _copytree(src: Path, dest: Path) -> None:
    dest.parent.mkdir(parents=True, exist_ok=True)
    if dest.exists() or dest.is_symlink():
        if dest.is_dir() and not dest.is_symlink():
            shutil.rmtree(dest)
        else:
            dest.unlink()
    shutil.copytree(src, dest, symlinks=True)


def sync_seed(paths: Paths) -> None:
    seed = paths.app_seed
    seed.mkdir(parents=True, exist_ok=True)
    _copytree(paths.repo / "src" / "etc", seed / "etc")
    _copytree(paths.repo / "src" / "usr" / "share" / "doc", seed / "doc")


def sync_web_assets(paths: Paths) -> None:
    if not (paths.web_dist / "index.html").is_file():
        raise SystemExit("paibuild: web dist missing; run the web build first")
    _copytree(paths.web_dist, paths.app_web_dist)


def _hash_bytes(data: bytes) -> str:
    digest = hashlib.sha256(data).digest()
    return "sha256=" + base64.urlsafe_b64encode(digest).rstrip(b"=").decode()


def inject_web_dist(wheel: Path, dist: Path) -> None:
    """Rewrite a wheel so it carries the built web dist next to pai_web."""
    if not (dist / "index.html").is_file():
        raise SystemExit(f"paibuild: web dist missing at {dist}")

    tmp = wheel.with_suffix(".tmp.whl")
    entries: list[tuple[zipfile.ZipInfo, bytes]] = []
    record_name: str | None = None

    with zipfile.ZipFile(wheel, "r") as src:
        for info in src.infolist():
            data = src.read(info.filename)
            if info.filename.endswith(".dist-info/RECORD"):
                record_name = info.filename
                continue
            entries.append((info, data))

    if record_name is None:
        raise SystemExit(f"paibuild: no RECORD in {wheel}")

    for file in iter_files(dist):
        rel = file.relative_to(dist).as_posix()
        info = zipfile.ZipInfo(f"usr/libexec/web/dist/{rel}")
        info.external_attr = (0o644 & 0xFFFF) << 16
        entries.append((info, file.read_bytes()))

    rows: list[list[str]] = []
    with zipfile.ZipFile(tmp, "w", compression=zipfile.ZIP_DEFLATED) as out:
        seen: set[str] = set()
        for info, data in entries:
            if info.filename in seen:
                continue
            seen.add(info.filename)
            out.writestr(info, data)
            rows.append([info.filename, _hash_bytes(data), str(len(data))])
        rows.append([record_name, "", ""])
        buf = io.StringIO()
        writer = csv.writer(buf, lineterminator="\n")
        writer.writerows(rows)
        out.writestr(record_name, buf.getvalue())

    tmp.replace(wheel)


def build_wheel(paths: Paths, runner: Runner) -> Path:
    if paths.wheel_dir.exists():
        shutil.rmtree(paths.wheel_dir)
    paths.wheel_dir.mkdir(parents=True, exist_ok=True)
    runner.run(["uv", "build", "--wheel", "--out-dir", str(paths.wheel_dir)], cwd=paths.repo)
    wheels = sorted(paths.wheel_dir.glob("*.whl"))
    if len(wheels) != 1:
        raise SystemExit(f"paibuild: expected one wheel in {paths.wheel_dir}, found {len(wheels)}")
    inject_web_dist(wheels[0], paths.web_dist)
    return wheels[0]


FALLBACK_DEFAULT_REGISTRY = "https://github.com/whitematterlabs/pairegistry"


def _is_registry_url(value: str) -> bool:
    return (
        value.startswith(("http://", "https://", "git+", "git@"))
        or value.startswith("github.com/")
        or value.startswith("gitlab.com/")
    )


def _clone_registry(url: str, into: Path) -> Path:
    if "@" in url and not url.startswith("git@"):
        url, ref = url.rsplit("@", 1)
    else:
        ref = None
    if url.startswith(("github.com/", "gitlab.com/")):
        url = "https://" + url
    cmd = ["git", "clone", "--depth", "1"]
    if ref:
        cmd += ["--branch", ref]
    cmd += [url, str(into)]
    subprocess.run(cmd, check=True)
    return into


def _paiman_default_registry(repo: Path) -> str:
    paiman = repo / "src" / "bin" / "paiman.py"
    try:
        tree = ast.parse(paiman.read_text(encoding="utf-8"))
    except OSError:
        return FALLBACK_DEFAULT_REGISTRY
    for node in tree.body:
        if not isinstance(node, ast.Assign):
            continue
        if not any(isinstance(t, ast.Name) and t.id == "DEFAULT_REGISTRY" for t in node.targets):
            continue
        if isinstance(node.value, ast.Constant) and isinstance(node.value.value, str):
            return node.value.value
    return FALLBACK_DEFAULT_REGISTRY


def _registry_root(repo: Path, work: Path) -> Path:
    loc = os.environ.get("PAIMAN_REGISTRY", _paiman_default_registry(repo))
    if _is_registry_url(loc):
        return _clone_registry(loc, work / "registry")
    root = Path(loc).expanduser()
    if not root.is_dir():
        raise SystemExit(
            f"paibuild: registry {loc!r} is not a directory or URL"
        )
    return root.resolve()


def _registry_has_package(root: Path, typed_name: str) -> bool:
    candidate = root / typed_name
    if (candidate / "package.yaml").is_file():
        return True
    head, _, tail = typed_name.partition("/")
    head_dir = root / head
    if head_dir.is_dir():
        for child in sorted(head_dir.iterdir()):
            if (child / tail / "package.yaml").is_file():
                return True
    return False


def validate_registry(paths: Paths) -> None:
    sys.path.insert(0, str(paths.repo / "src"))
    try:
        from bin import paifs_init
    finally:
        try:
            sys.path.remove(str(paths.repo / "src"))
        except ValueError:
            pass

    required = (
        [f"prompts/{n}" for n in paifs_init.ROOT_SEED_PROMPTS]
        + [f"drivers/{n}" for n in paifs_init.KERNEL_SEED_DRIVERS]
        + [f"skills/{n}" for n in paifs_init.KERNEL_SEED_SKILLS]
        + [f"bin/{n}" for n in paifs_init.KERNEL_SEED_BINS]
        + [f"pais/{n}" for n in paifs_init.KERNEL_SEED_PAIS]
    )
    missing: list[str] = []
    with tempfile.TemporaryDirectory(prefix="paibuild-registry-") as td:
        registry = _registry_root(paths.repo, Path(td))
        for name in required:
            if not _registry_has_package(registry, name):
                missing.append(name)
    if missing:
        joined = ", ".join(missing)
        raise SystemExit(
            "paibuild: required first-run package(s) missing from paiman "
            f"registry: {joined}\n"
            "Fix the registry or rerun with --skip-registry-check for a local-only build."
        )


def stage_swift_app(paths: Paths, options: Options) -> None:
    derived = paths.derived_app(options.config)
    if not derived.is_dir():
        raise SystemExit(f"paibuild: xcodebuild produced no app at {derived}")

    stash = paths.build_dir / ".paibuild-resource-stash"
    if stash.exists():
        shutil.rmtree(stash)
    stash.mkdir(parents=True)

    if paths.final_app.is_dir() and not options.full:
        for rel in (
            Path("Contents/Resources/runtime"),
            Path("Contents/Resources/seed"),
            Path("Contents/Resources/usr/libexec/web/dist"),
        ):
            src = paths.final_app / rel
            if src.exists():
                _copytree(src, stash / rel)

    if paths.final_app.exists():
        shutil.rmtree(paths.final_app)
    shutil.copytree(derived, paths.final_app, symlinks=True)

    for rel in (
        Path("Contents/Resources/runtime"),
        Path("Contents/Resources/seed"),
        Path("Contents/Resources/usr/libexec/web/dist"),
    ):
        src = stash / rel
        if src.exists():
            _copytree(src, paths.final_app / rel)
    shutil.rmtree(stash)


def sign_and_verify(paths: Paths, *, notarize: bool) -> None:
    sign_id = os.environ.get("SIGN_ID", DEFAULT_SIGN_ID)
    notary_profile = os.environ.get("NOTARY_PROFILE", DEFAULT_NOTARY_PROFILE)
    entitlements = paths.macos / "PAI" / "PAI.entitlements"
    runtime = paths.app_runtime
    pydir = runtime / "python"

    def run(cmd: list[str]) -> None:
        subprocess.run(cmd, check=True)

    def sign_nested(path: Path) -> None:
        if sign_id == "-":
            subprocess.run(["codesign", "--force", "--sign", "-", str(path)], check=False)
        else:
            run(["codesign", "--force", "--options", "runtime", "--timestamp", "--sign", sign_id, str(path)])

    def sign_binary(path: Path) -> None:
        if not path.exists():
            return
        if sign_id == "-":
            subprocess.run(["codesign", "--force", "--sign", "-", str(path)], check=False)
        else:
            run([
                "codesign", "--force", "--options", "runtime", "--timestamp",
                "--entitlements", str(entitlements), "--sign", sign_id, str(path),
            ])

    def sign_app(path: Path) -> None:
        if sign_id == "-":
            run(["codesign", "--force", "--entitlements", str(entitlements), "--sign", "-", str(path)])
        else:
            run([
                "codesign", "--force", "--options", "runtime", "--timestamp",
                "--entitlements", str(entitlements), "--sign", sign_id, str(path),
            ])

    if runtime.exists():
        for lib in sorted(runtime.rglob("*")):
            if lib.is_file() and lib.suffix in {".dylib", ".so"}:
                sign_nested(lib)
        sign_binary(pydir / "bin" / f"python{PYVER}")
        sign_binary(runtime / "bin" / "tmux")
        sign_binary(runtime / "bin" / "CoreLocationCLI")

    sign_app(paths.final_app)
    run(["codesign", "--verify", "--deep", "--strict", str(paths.final_app)])

    if notarize:
        if sign_id == "-":
            print("note: --notarize ignored for an ad-hoc build (needs SIGN_ID)")
            return
        probe = subprocess.run(
            ["xcrun", "notarytool", "history", "--keychain-profile", notary_profile],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        if probe.returncode != 0:
            print(f"note: no notarytool credentials for profile {notary_profile!r}; skipping")
            return
        zip_path = paths.final_app.with_name("PAI-notarize.zip")
        if zip_path.exists():
            zip_path.unlink()
        run(["ditto", "-c", "-k", "--keepParent", str(paths.final_app), str(zip_path)])
        run(["xcrun", "notarytool", "submit", str(zip_path), "--keychain-profile", notary_profile, "--wait"])
        run(["xcrun", "stapler", "staple", str(paths.final_app)])
        zip_path.unlink(missing_ok=True)


class Builder:
    def __init__(self, paths: Paths, options: Options, runner: Runner | None = None) -> None:
        self.paths = paths
        self.options = options
        self.runner = runner or Runner()

    def run(self) -> int:
        if self.options.full and not self.options.dry_run:
            self.paths.build_dir.mkdir(parents=True, exist_ok=True)
            if self.paths.final_app.exists():
                shutil.rmtree(self.paths.final_app)
            derived = self.paths.derived_app(self.options.config)
            if derived.exists():
                shutil.rmtree(derived)

        fp = digest_inputs(self.paths)
        state = load_state(self.paths.state_file)
        plan = make_plan(self.paths, self.options, state, fp)
        print_plan(plan)
        if self.options.dry_run:
            return 0

        self.paths.build_dir.mkdir(parents=True, exist_ok=True)

        if plan.registry_check:
            validate_registry(self.paths)

        if plan.web_deps:
            self.runner.run(["pnpm", "install", "--frozen-lockfile"], cwd=self.paths.web_dir)
        if plan.web:
            self.runner.run(["pnpm", "build"], cwd=self.paths.web_dir)

        if plan.swift:
            self.runner.run(["xcodegen", "generate"], cwd=self.paths.macos)
            self.runner.run([
                "xcodebuild",
                "-project", str(self.paths.macos / "PAI.xcodeproj"),
                "-scheme", "PAI",
                "-configuration", self.options.config,
                "-derivedDataPath", str(self.paths.derived_data),
                "build",
            ])
            stage_swift_app(self.paths, self.options)

        if not self.paths.final_app.is_dir():
            raise SystemExit("paibuild: final app missing after Swift build")

        if plan.full_runtime:
            self.runner.run([str(self.paths.macos / "bundle-runtime.sh"), str(self.paths.final_app)])

        if plan.python_package:
            wheel = build_wheel(self.paths, self.runner)
            self.runner.run([
                str(self.paths.app_python),
                "-m",
                "pip",
                "install",
                "--no-deps",
                "--force-reinstall",
                "--no-warn-script-location",
                str(wheel),
            ])

        if plan.seed and not plan.full_runtime:
            sync_seed(self.paths)

        if plan.web_assets:
            sync_web_assets(self.paths)

        if plan.sign or self.options.notarize:
            sign_and_verify(self.paths, notarize=self.options.notarize)
        else:
            try:
                self.runner.run(["codesign", "--verify", "--deep", "--strict", str(self.paths.final_app)])
            except subprocess.CalledProcessError:
                print("paibuild: existing app signature is invalid; re-signing", flush=True)
                sign_and_verify(self.paths, notarize=self.options.notarize)

        if plan.dmg:
            self.runner.run([str(self.paths.macos / "package-dmg.sh"), str(self.paths.final_app), str(self.paths.dmg)])

        final_fp = digest_inputs(self.paths)
        save_state(self.paths, self.options, final_fp)
        print(f"Built: {self.paths.final_app}")
        return 0


def parse_args(argv: list[str]) -> Options:
    parser = argparse.ArgumentParser(description="Build final PAI.app from the repo")
    parser.add_argument("config", nargs="?", choices=("Debug", "Release"), help=argparse.SUPPRESS)
    parser.add_argument("--debug", action="store_true", help="build Debug instead of Release")
    parser.add_argument("--full", action="store_true", help="rebuild app output and embedded Python runtime")
    parser.add_argument("--dmg", action="store_true", help="also package macos/build/PAI.dmg")
    parser.add_argument("--notarize", action="store_true", help="notarize after signing when SIGN_ID is set")
    parser.add_argument("--dry-run", action="store_true", help="print planned rebuilds without changing outputs")
    parser.add_argument(
        "--skip-registry-check",
        action="store_true",
        help="skip validation of remote first-run paiman seed packages",
    )
    args = parser.parse_args(argv)
    config = "Debug" if args.debug or args.config == "Debug" else "Release"
    return Options(
        config=config,
        full=args.full,
        dmg=args.dmg,
        notarize=args.notarize,
        dry_run=args.dry_run,
        skip_registry_check=args.skip_registry_check,
    )


def main(argv: list[str] | None = None) -> int:
    repo = Path(__file__).resolve().parent
    options = parse_args(sys.argv[1:] if argv is None else argv)
    return Builder(Paths(repo), options).run()


if __name__ == "__main__":
    raise SystemExit(main())
